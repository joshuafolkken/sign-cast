{
	"name": "lumina",
	"version": "0.32.0",
	"private": true,
	"description": "SvelteKit app with Cloudflare Workers",
	"type": "module",
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"engines": {
		"node": ">=22.16.0",
		"pnpm": ">=10.32.1"
	},
	"pnpm": {
		"overrides": {
			"@hono/node-server": ">=1.19.10",
			"cookie": ">=0.7.0",
			"devalue": ">=5.6.4",
			"esbuild": ">=0.25.0",
			"hono": ">=4.12.4",
			"kysely": ">=0.28.12",
			"lodash": ">=4.17.23",
			"undici": ">=7.24.0"
		},
		"ignoredBuiltDependencies": [
			"lefthook"
		]
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm && pnpm dlx @aikidosec/safe-chain setup-ci",
		"postinstall": "lefthook install",
		"prepare": "pnpm gen && pnpm paraglide:compile && svelte-kit sync",
		"dev": "vite dev",
		"dev:cloudflare": "pnpm build && wrangler dev --remote",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"preview:normal": "vite preview",
		"preview:stop": "kill-port 4173 || true",
		"check": "pnpm paraglide:compile && svelte-kit sync && svelte-fast-check --incremental",
		"check:ci": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "svelte-kit sync && pnpm lint:prettier && pnpm lint:eslint",
		"lint:prettier": "prettier --check .",
		"lint:eslint": "eslint . --cache --cache-strategy content",
		"format": "svelte-kit sync && pnpm format:prettier && pnpm format:eslint",
		"format:prettier": "prettier --write .",
		"format:eslint": "eslint . --fix --cache --cache-strategy content",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"gen": "pnpm gen:pre && wrangler types",
		"gen:pre": "rm -f .svelte-kit/cloudflare/_worker.*",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --emit-ts-declarations",
		"update:corepack": "corepack use pnpm@latest",
		"update:latest": "pnpm update --latest",
		"cspell:dot": "cspell . --dot",
		"check-commit-message": "tsx scripts/check-commit-message.ts",
		"prevent-main-commit": "tsx scripts/prevent-main-commit.ts",
		"git": "tsx scripts/git-workflow.ts",
		"version:minor": "pnpm version minor --no-git-tag-version --loglevel=error",
		"lefthook:commit": "lefthook run pre-commit",
		"lefthook:push": "lefthook run pre-push",
		"main:sync": "git checkout main && git pull",
		"main:merge": "git pull origin main",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@inlang/paraglide-js": "^2.15.0",
		"@libsql/client": "^0.17.0",
		"@playwright/test": "^1.58.2",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.0",
		"better-auth": "~1.5.5",
		"cspell": "^9.7.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-sonarjs": "^4.0.2",
		"eslint-plugin-svelte": "^3.15.2",
		"eslint-plugin-unicorn": "^63.0.0",
		"globals": "^17.4.0",
		"kill-port": "^2.0.1",
		"lefthook": "^2.1.4",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.5",
		"svelte-fast-check": "^0.4.5",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.75.0"
	}
}
